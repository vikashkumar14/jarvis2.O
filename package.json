{
  "name": "jarvis-2-0",
  "version": "1.2.3",
  "description": "JARVIS 2.O is not another chatbot you type at. It is an intelligent Voice-First Operating Layer that gives you complete, hands-free authority over your digital environment. It lives on your desktop, watches your workflow, and executes your intent instantly.",
  "main": "./out/main/index.js",
  "author": "vikash",
  "homepage": "https://jarvisai.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/vikashkumar14/IRIS-AI.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "build:unpack": "if exist dist rmdir /s /q dist && npm run build && set \"PATH=%SystemRoot%\\system32;%PATH%\" && set \"ComSpec=%SystemRoot%\\system32\\cmd.exe\" && electron-builder --dir",
    "build:win": "node scripts/build-win.js",
    "release:win": "node scripts/build-win.js --publish",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
